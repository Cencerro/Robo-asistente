# =============================================================================
# Robo-assistente — Variables de entorno
# Copiar este fichero a .env y completar los valores
# =============================================================================

# --- Claude (requerido) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Telegram (requerido) ---
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=-100123456789

# --- Mistral (opcional, para tareas simples en el futuro) ---
# MISTRAL_API_KEY=...

# --- Configuración general ---
LOG_LEVEL=INFO
DATA_DIR=data

# --- Opciones de red/SSL ---
# Si el entorno no tiene certificados de CA instalados correctamente,
# puede forzar a ignorar la verificación SSL (NO RECOMENDADO para producción).
VERIFY_SSL=True

# --- Opciones de Anthropic / Claude ---
# Este valor controla si se incluye el encabezado "anthropic-beta".
# La API puede devolver errores si se usa un valor no esperado.
# Dejar en blanco para no enviar el encabezado.
ANTHROPIC_BETA=

# --- Tarea menu ---
MENU_SOURCE_URL=https://www.maisonslaffitte.fr/restauration-scolaire/10166/
