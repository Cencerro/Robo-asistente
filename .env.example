# --- Claude (requerido) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Telegram (requerido) ---
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=-100123456789

# --- Mistral (opcional, para tareas simples en el futuro) ---
# MISTRAL_API_KEY=...

# --- Configuración general ---
LOG_LEVEL=INFO
DATA_DIR=data

# --- Tarea menu ---
MENU_SOURCE_URL=https://www.maisonslaffitte.fr/restauration-scolaire/10166/
